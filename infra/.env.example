# Copy to infra/.env and fill in. NEVER commit the real .env.
# These are the Phase 0 secrets — they live here on the VPS only.

# --- Notion (nightly sync) ---
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=2ccd6351713d452fb4c79622f71962d2

# --- GitHub (n8n creates customer repos) ---
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_ORG=your-org

# --- Render (n8n creates static sites + deploys) ---
RENDER_API_KEY=rnd_xxxxxxxxxxxx

# --- Simply.com mail (send + read) ---
SIMPLY_SMTP_HOST=smtp.simply.com
SIMPLY_SMTP_PORT=587
SIMPLY_IMAP_HOST=mail.simply.com
SIMPLY_IMAP_PORT=143
SIMPLY_MAIL_USER=hej@wilbrandtworks.dk
SIMPLY_MAIL_PASS=xxxxxxxx

# --- Claude (overnight prep on your Max subscription) ---
# From `claude setup-token` on your laptop (1-year token).
CLAUDE_CODE_OAUTH_TOKEN=xxxxxxxx

# --- pipeline knobs ---
SCAN_AREA=denmark
SHOT_LIMIT=200      # scored leads that get a (free) screenshot -> become classifiable
PREP_LIMIT=40       # leads Claude classifies per night (budget dial; ~half come out 'ugly')
DEMO_LIMIT=12       # demos auto-built per night (biggest budget dial — full site designs)
FIX_LIMIT=2         # support tickets auto-fixed per night
LEADS_DB=/opt/coldoutreaches/data/leads.db
